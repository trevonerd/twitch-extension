{
  "name": "drophunter",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/trevonerd/drophunter/"
  },
  "scripts": {
    "clean": "rm -rf dist video/out",
    "dev": "vite",
    "build": "vite build",
    "check": "bun run test:ts && bun run lint && bun run test && bun run build",
    "video:install": "cd video && bun install",
    "video:preview": "cd video && bun run preview",
    "video:render:cta": "cd video && bun run render:cta",
    "video:still:cta": "cd video && bun run still:cta",
    "video:render:promo": "cd video && bun run render:promo",
    "video:still:promo": "cd video && bun run still:promo",
    "test:ts": "tsc --noEmit",
    "test": "bun test tests/",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "deps:outdated": "bun outdated",
    "deps:audit": "bun audit",
    "update": "bun update --latest && cd video && bun update --latest",
    "update:interactive": "bun update -i --latest && cd video && bun update -i --latest",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@tailwindcss/postcss": "4.2.2",
    "@types/chrome": "0.1.38",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
